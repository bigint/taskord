{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^7.2.5",
        "albertcht/invisible-recaptcha": "1.9.4",
        "askedio/laravel5-profanity-filter": "1.10",
        "cyrildewit/eloquent-viewable": "5.2.0",
        "fideloper/proxy": "4.4.0",
        "fruitcake/laravel-cors": "2.0.1",
        "fzaninotto/faker": "1.9.1",
        "graham-campbell/markdown": "13.1.0",
        "grosv/laravel-passwordless-login": "1.2.0",
        "guzzlehttp/guzzle": "6.5.5",
        "laravel/framework": "7.25.0",
        "laravel/socialite": "4.4.1",
        "laravel/telescope": "3.5.1",
        "laravel/tinker": "2.4.2",
        "laravel/ui": "2.1.0",
        "livewire/livewire": "1.3.2",
        "marvinlabs/laravel-discord-logger": "1.1.5",
        "nesbot/carbon": "2.38.0",
        "overtrue/laravel-follow": "2.1.1",
        "overtrue/laravel-like": "2.0.0",
        "qcod/laravel-gamify": "1.0.4",
        "rebing/graphql-laravel": "5.1.2",
        "rennokki/laravel-eloquent-query-cache": "2.2.0",
        "sentry/sentry-laravel": "1.8.0",
        "spatie/emoji": "2.1.2",
        "spatie/laravel-backup": "6.11.1",
        "spatie/laravel-personal-data-export": "1.3.1",
        "stevebauman/purify": "3.0.2",
        "valorin/pwned-validator": "1.3.2"
    },
    "require-dev": {
        "facade/ignition": "2.3.6",
        "mockery/mockery": "1.4.2",
        "nunomaduro/collision": "4.2.0",
        "phpunit/phpunit": "9.3.7"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "classmap": [
            "database/seeds",
            "database/factories"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
